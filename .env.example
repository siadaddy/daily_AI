# 이 파일은 환경변수 템플릿입니다. 실제 값은 .env.local에 설정하세요.
# .env.local은 git에 커밋되지 않습니다.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI API (주간 브리핑 자동 생성 — gpt-4o-mini)
OPENAI_API_KEY=

# Vercel Cron 보안 시크릿 — 임의의 긴 랜덤 문자열
# 생성 예시: openssl rand -hex 32
# Vercel 프로젝트 설정 → Environment Variables에도 동일하게 추가
CRON_SECRET=

# Supabase service-role 키 — 주간/월간 리포트 upsert(RLS 우회)에 필요
# Supabase 대시보드 → Settings → API keys. 서버 전용, NEXT_PUBLIC_ 금지
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API — 음악 탭 검색
YOUTUBE_API_KEY=
